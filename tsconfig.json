{
  "compilerOptions": {
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "esModuleInterop": true,
    "lib": ["es5", "es2015", "esnext", "dom"],
    "types": ["node"],
    "moduleResolution": "bundler",
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "sourceMap": true,
    "strict": true,
    "rootDir": "./",
    "target": "esnext"
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts"
  ]
}
